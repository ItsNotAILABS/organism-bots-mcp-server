{
  "schema": "mcp.organism_bots.server.v2",
  "name": "NOVA Organism Bots MCP",
  "description": "MCP-style server contract for discovering organism bots, submitting bot tasks, importing artifacts, producing readiness reports, and routing business-building work through governed bot organs.",
  "resources": [
    {
      "uri": "nova://organism-bots/registry",
      "name": "Organism Bot Registry",
      "path": "organism-bots.registry.json"
    },
    {
      "uri": "nova://organism-bots/research",
      "name": "Organism Bots Research Paper",
      "path": "research/ORGANISM_BOTS_PLATFORM_RESEARCH.md"
    },
    {
      "uri": "nova://organism-bots/readiness",
      "name": "Product Readiness Guide",
      "path": "docs/PRODUCT_READINESS.md"
    }
  ],
  "tools": [
    {
      "name": "organism_bots.list",
      "input_schema": {},
      "output": "List registered organism bots."
    },
    {
      "name": "organism_bots.describe",
      "input_schema": {
        "bot_id": "string"
      },
      "output": "Return bot role, houses, inputs, outputs, proof gates, and launch level."
    },
    {
      "name": "organism_bots.submit_task",
      "input_schema": {
        "bot_id": "string",
        "task": "string",
        "target": "string",
        "operator_scope": "string"
      },
      "output": "Task receipt with proof gates."
    },
    {
      "name": "organism_bots.route_plan",
      "input_schema": {
        "task": "string",
        "target_surface": "string",
        "risk_level": "string"
      },
      "output": "Suggested bot route with required proof gates and next handoff."
    },
    {
      "name": "organism_bots.import_artifact",
      "input_schema": {
        "task_id": "string",
        "artifact_url": "string",
        "sha256": "string"
      },
      "output": "Artifact import manifest."
    },
    {
      "name": "organism_bots.readiness_report",
      "input_schema": {
        "bot_id": "string",
        "target_level": "string"
      },
      "output": "Launch readiness report with gaps and promotion gates."
    }
  ],
  "proof_gates": ["bot id exists", "operator scope recorded", "task receipt created", "artifact hash verified", "launch level declared"]
}
